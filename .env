# Copia a `.env` y rellena los valores. No subas `.env` al control de versiones.

# Clave de la API de Google AI (Gemini). No la compartas ni la registres en logs.
GEMINI_API_KEY=AIzaSyCdOJY-IEuY6Cm-ZRsC80wSzT-CD1fVqn0

# Modelo sugerido para el supervisor (ajusta si tu cuenta soporta otro id).
GEMINI_MODEL=gemini-2.5-flash-lite

# Raíz del proyecto donde deben ejecutarse tests y cursor-agent (Windows: ruta absoluta recomendada).
PROJECT_PATH=C:/Users/santi/OneDrive/Documentos/operador

# Opcional: timeout en segundos para la llamada HTTP a Gemini (default 120).
# GEMINI_TIMEOUT_SEC=120

# Opcional: base URL alternativa (muy raro; default Google).
# GEMINI_API_BASE=https://generativelanguage.googleapis.com

# Opcional: ejecutable y modo de invocación de Cursor Agent (ajusta a tu instalación).
# CURSOR_AGENT_BIN=cursor-agent
# CURSOR_AGENT_EXTRA_ARGS=
# CURSOR_AGENT_USE_STDIN=0
# CURSOR_AGENT_USE_FILE=0
# CURSOR_AGENT_FILE_FLAG=--prompt-file
# CURSOR_TIMEOUT_SEC=3600

# Opcional: tests (ver test_runner.py).
# AUTO_LOOP_PYTEST=1
# AUTO_LOOP_RUFF=0
# AUTO_LOOP_SIM_SCRIPT=
# AUTO_LOOP_TIMEOUT_PYTEST=600
