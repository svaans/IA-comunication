# Copia a `.env` y rellena los valores. No subas `.env` al control de versiones.

# Clave de la API de Google AI (Gemini). No la compartas ni la registres en logs.
# Si Google responde 403 "leaked", la clave quedó comprometida: genera otra en AI Studio y revoca la vieja.
GEMINI_API_KEY=

# Modelo sugerido para el supervisor (ajusta si tu cuenta soporta otro id).
GEMINI_MODEL=gemini-2.5-flash-lite

# Modelos de respaldo si el primario devuelve 429/404/503 (lista separada por comas).
# Vacío o 0 = solo GEMINI_MODEL. Por defecto (si no defines la variable): gemini-2.0-flash,gemini-1.5-flash
# GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-1.5-flash

# Opcional: ante 429, esperar antes de pasar al siguiente modelo (puede ayudar con RPM).
# GEMINI_429_SLEEP_BEFORE_FALLBACK=0
# GEMINI_429_RETRY_MAX_SLEEP_SEC=60

# Raíz del proyecto donde deben ejecutarse tests y cursor-agent (Windows: ruta absoluta recomendada).
PROJECT_PATH=

# Opcional: timeout en segundos para la llamada HTTP a Gemini (default 120).
# GEMINI_TIMEOUT_SEC=120

# Opcional: base URL alternativa (muy raro; default Google).
# GEMINI_API_BASE=https://generativelanguage.googleapis.com

# Cursor Agent (CLI): autenticación en la máquina donde corre el bucle.
# Si ves "Authentication required", ejecuta una vez: `cursor-agent login`
# o define la clave de API de Cursor (no la subas al repo):
# CURSOR_API_KEY=

# Confianza del workspace (modo no interactivo). Si Cursor pide "Workspace Trust Required",
# por defecto se pasa --trust. Desactiva solo si no confías en el directorio del proyecto.
# CURSOR_AGENT_TRUST_WORKSPACE=1
# CURSOR_AGENT_TRUST_FLAGS=--trust

# Si Cursor devuelve cuota agotada / "Switch to Auto", reintentar con --model auto (sin error si tiene éxito).
# CURSOR_AGENT_AUTO_MODEL_FALLBACK=1
# CURSOR_AGENT_AUTO_MODEL_NAME=auto

# Opcional: ejecutable y modo de invocación de Cursor Agent (ajusta a tu instalación).
# En Windows, si ves WinError 2, pon aquí la ruta absoluta al .exe o .cmd de la CLI.
# CURSOR_AGENT_BIN=cursor-agent
# CURSOR_AGENT_BIN=C:\Ruta\Completa\cursor-agent.exe
# CURSOR_AGENT_EXTRA_ARGS=
# CURSOR_AGENT_USE_STDIN=0
# CURSOR_AGENT_USE_FILE=0
# CURSOR_AGENT_FILE_FLAG=--prompt-file
# CURSOR_TIMEOUT_SEC=3600

# Tras un fallo de autenticación de cursor-agent, omitir llamadas en iteraciones siguientes
# (el bucle sigue con Gemini + tests). Primera iteración seguirá intentando Cursor.
# AUTO_LOOP_SKIP_CURSOR_AFTER_AUTH_ERROR=0

# Tras mensaje de cuota/uso agotado de Cursor ("out of usage"), omitir Cursor en iteraciones siguientes.
# AUTO_LOOP_SKIP_CURSOR_AFTER_USAGE_ERROR=0

# Opcional: tests (ver test_runner.py).
# AUTO_LOOP_PYTEST=1
# Si no tienes pytest en el venv, el bucle lo omite salvo que pongas:
# AUTO_LOOP_REQUIRE_PYTEST=1
# AUTO_LOOP_PYTEST_ALLOW_NO_TESTS=1
# AUTO_LOOP_SYNTAX_CHECK=1
# AUTO_LOOP_RUFF=0
# AUTO_LOOP_SIM_SCRIPT=
# AUTO_LOOP_TIMEOUT_PYTEST=600
